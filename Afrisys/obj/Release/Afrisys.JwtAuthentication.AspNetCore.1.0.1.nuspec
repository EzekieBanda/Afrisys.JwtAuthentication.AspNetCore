<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2012/06/nuspec.xsd">
  <metadata>
    <id>Afrisys.JwtAuthentication.AspNetCore</id>
    <version>1.0.1</version>
    <authors>EzekDev</authors>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <readme>README.md</readme>
    <description>Lightweight JWT authentication and authorization library for ASP.NET Core APIs, enforcing secure microservice communication using an Audience-based scope model. Simplifies API protection with plug-and-play configuration, eliminating complex policies while ensuring strict service-to-service isolation.</description>
    <releaseNotes>Fixed JWT validation issue caused by dependency conflicts with Microsoft.IdentityModel packages.</releaseNotes>
    <tags>jwt authentication authorization aspnetcore webapi security oauth2 openidconnect microservices api-security bearer-token</tags>
    <repository type="git" />
    <dependencies>
      <group targetFramework="net10.0">
        <dependency id="Microsoft.AspNetCore.Authentication.JwtBearer" version="10.0.7" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
  <files>
    <file src="D:\DotNet\Afrisys\Afrisys\bin\Release\net10.0\Afrisys.dll" target="lib\net10.0\Afrisys.dll" />
    <file src="D:\DotNet\Afrisys\Afrisys\README.md" target="\README.md" />
  </files>
</package>